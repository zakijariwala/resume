---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <meta name="theme-color" content="#1A6BFF" />

    <!-- Cloudflare Web Analytics — replace token with value from Cloudflare Pages dashboard -->
    <!-- Alternatively, enable via Cloudflare Pages Settings → Web Analytics (no code change needed) -->
    <!-- <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token":"YOUR_CF_ANALYTICS_TOKEN"}'></script> -->

    <!-- FOUC prevention: sets data-mode and data-theme before first paint -->
    <script is:inline>
      (function () {
        const params = new URLSearchParams(window.location.search);
        let mode = params.get('mode');
        let theme = params.get('theme');

        const validModes = ['recruiter', 'developer', 'curious'];
        const validThemes = ['light', 'dark'];

        if (mode && validModes.includes(mode)) {
          localStorage.setItem('portfolio_mode', mode);
        } else {
          mode = localStorage.getItem('portfolio_mode');
          if (!mode || !validModes.includes(mode)) mode = 'recruiter';
        }

        if (theme && validThemes.includes(theme)) {
          localStorage.setItem('portfolio_theme', theme);
        } else {
          theme = localStorage.getItem('portfolio_theme');
          if (!theme || !validThemes.includes(theme)) theme = 'light';
        }

        document.documentElement.setAttribute('data-mode', mode);
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('portfolio_mode', mode);
        localStorage.setItem('portfolio_theme', theme);

        const newSearch = '?mode=' + mode;
        if (window.location.search !== newSearch) {
          window.history.replaceState(null, '', newSearch);
        }
      })();
    </script>
  </head>

  <body>
    <script is:inline>
      (function () {
        const mode = document.documentElement.getAttribute('data-mode');
        const theme = document.documentElement.getAttribute('data-theme');
        document.body.setAttribute('data-mode', mode);
        document.body.setAttribute('data-theme', theme);
      })();
    </script>

    <!-- Mode-change toast -->
    <div
      id="mode-toast"
      class="fixed left-0 right-0 z-40 flex items-center justify-center h-8 text-xs font-semibold opacity-0 pointer-events-none transition-opacity duration-300"
      style="top: var(--nav-height); background: var(--accent-subtle); color: var(--accent-text);"
    ></div>

    <div id="app" class="min-h-screen flex flex-col">
      <slot />
    </div>

    <!-- Scroll reveal -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver(
          (entries) => entries.forEach(e => {
            if (e.isIntersecting) e.target.classList.add('visible');
          }),
          { threshold: 0.12 }
        );
        document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
      });
    </script>
  </body>
</html>
