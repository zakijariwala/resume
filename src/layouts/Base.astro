---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph Metadata -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    
    <!-- Theme Color tied to Active Accent Mode -->
    <meta name="theme-color" content="var(--accent)" />
    
    <!-- Synchronous FOUC-Prevention Script (Sets attributes prior to paint) -->
    <script is:inline>
      (function () {
        const params = new URLSearchParams(window.location.search);
        let mode = params.get('mode');
        let theme = params.get('theme');

        const validModes = ['recruiter', 'developer', 'curious'];
        const validThemes = ['light', 'dark'];

        // 1. Read URL param first, save if valid
        if (mode && validModes.includes(mode)) {
          localStorage.setItem('portfolio_mode', mode);
        } else {
          // 2. If no param or invalid, read localStorage, default to recruiter
          mode = localStorage.getItem('portfolio_mode');
          if (!mode || !validModes.includes(mode)) {
            mode = 'recruiter';
          }
        }

        // Apply same hierarchy to theme
        if (theme && validThemes.includes(theme)) {
          localStorage.setItem('portfolio_theme', theme);
        } else {
          theme = localStorage.getItem('portfolio_theme');
          if (!theme || !validThemes.includes(theme)) {
            theme = 'light';
          }
        }

        // Apply immediately to html tag for initial styled rendering before paint
        document.documentElement.setAttribute('data-mode', mode);
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('portfolio_mode', mode);
        localStorage.setItem('portfolio_theme', theme);

        // Ensure URL always reflects active mode without reload
        const newSearch = '?mode=' + mode;
        if (window.location.search !== newSearch) {
          window.history.replaceState(null, '', newSearch);
        }
      })();
    </script>
  </head>
  
  <body class="transition-colors duration-150">
    <!-- Double-apply attributes to body tag once DOM initializes to guarantee compatibility with nested body selectors -->
    <script is:inline>
      (function () {
        const mode = document.documentElement.getAttribute('data-mode');
        const theme = document.documentElement.getAttribute('data-theme');
        document.body.setAttribute('data-mode', mode);
        document.body.setAttribute('data-theme', theme);
      })();
    </script>
    
    <!-- Dynamic Mode-Change Visual Toast -->
    <div id="mode-toast" class="fixed top-[52px] left-0 right-0 h-8 flex items-center justify-center bg-[var(--accent-muted)] text-accent text-xs font-semibold z-40 opacity-0 pointer-events-none transition-opacity duration-300"></div>
    
    <div id="app" class="min-h-screen flex flex-col">
      <slot />
    </div>

    <!-- Synchronous load animation script -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const app = document.getElementById('app');
        if (app) {
          app.style.opacity = '1';
        }
      });
    </script>
  </body>
</html>
