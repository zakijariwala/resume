---
import resume from '../data/resume.json';

const { name, email, pdf_path, taglines, whatsapp } = resume.meta;

// Dynamically resolve base path for subfolder deployments (e.g. Astro /resume path)
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolvedPdfPath = pdf_path.startsWith('http') ? pdf_path : `${basePath}/${pdf_path.replace(/^\//, '')}`;
---

<section id="hero" class="pt-20 pb-12 flex flex-col justify-center text-center lg:text-left transition-all duration-150">
  <!-- Name Heading -->
  <h1 class="text-[28px] leading-tight font-medium text-text-primary">
    {name}
  </h1>

  <!-- Dynamic Role Tagline Spans (Resilient pure-CSS hiding mechanisms) -->
  <p class="text-base font-medium text-text-secondary mt-3 min-h-[24px]">
    <span class="recruiter-only inline-block">{taglines.recruiter}</span>
    <span class="dev-only inline-block">{taglines.developer}</span>
    <span class="curious-only inline-block">{taglines.curious}</span>
  </p>

  <!-- Outlined Action Buttons (Side-by-side flex layout with automatic wrap protection) -->
  <div class="flex flex-row items-center justify-center lg:justify-start gap-3 sm:gap-4 mt-8">
    <a 
      href={resolvedPdfPath} 
      download 
      class="inline-flex items-center justify-center gap-1.5 sm:gap-2 min-h-[44px] px-4 sm:px-6 py-2 border border-accent text-accent hover:bg-accent hover:text-white rounded-pill transition-colors duration-150 text-xs sm:text-sm font-semibold focus-visible:outline-accent whitespace-nowrap"
      aria-label="Download PDF Resume"
    >
      <i class="ti ti-download text-sm sm:text-base" aria-hidden="true"></i>
      <span>Download resume</span>
    </a>
    
    {whatsapp && (
      <a 
        href={whatsapp} 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-1.5 sm:gap-2 min-h-[44px] px-4 sm:px-6 py-2 border border-accent text-accent hover:bg-accent hover:text-white rounded-pill transition-colors duration-150 text-xs sm:text-sm font-semibold focus-visible:outline-accent whitespace-nowrap"
        aria-label="Talk to me on WhatsApp"
      >
        <i class="ti ti-brand-whatsapp text-sm sm:text-base" aria-hidden="true"></i>
        <span>Talk to me</span>
      </a>
    )}
  </div>
</section>
