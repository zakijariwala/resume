---
import certifications from '../data/certifications.json';
import SectionHeader from './SectionHeader.astro';
---

<section id="certifications" class="section-spacing" style="border-bottom: 1px solid var(--border);">
  <SectionHeader
    label="CERTIFICATIONS"
    labelDev="certifications"
    labelCurious="Certifications"
    title="Certifications"
  />

  <div class="cert-grid">
    {certifications.map((cert, i) => {
      const isProgress = cert.status === 'in_progress';
      return (
        <div
          class={`cert-card card fade-in ${isProgress ? 'dev-only curious-only' : 'all-modes'}`}
          style={`transition-delay: ${i * 0.05}s`}
        >
          <div class="cert-top">
            <span class={`badge ${isProgress ? 'badge-ongoing' : 'badge-done'}`}>
              {isProgress ? 'In Progress' : 'Completed'}
            </span>
            <span class="cert-year">{cert.year}</span>
          </div>

          <h3 class="cert-name">{cert.name}</h3>
          <p class="cert-issuer">{cert.issuer}</p>

          {cert.note && (
            <div class="callout dev-only curious-only cert-note">
              <p>{cert.note}</p>
            </div>
          )}
        </div>
      );
    })}
  </div>
</section>

<style>
.section-spacing {
  padding: var(--section-padding) 0;
}
.cert-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-4);
}
@media (max-width: 768px) {
  .cert-grid { grid-template-columns: 1fr; }
}
.cert-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
.cert-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
}
.cert-year {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--text-disabled);
}
.cert-name {
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: 400;
  color: var(--text);
  line-height: 1.3;
  margin: 0;
  font-optical-sizing: auto;
}
.cert-issuer {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--text-muted);
  margin: 0;
}
.cert-note {
  margin-top: auto;
}
.cert-note p {
  font-size: var(--text-xs);
  color: var(--text-muted);
  line-height: 1.65;
  font-style: italic;
  margin: 0;
}
</style>
