---
import resume from '../data/resume.json';

const certificationsData = resume.certifications;
---

<section id="certifications" class="py-12 border-b border-border transition-all duration-150">
  <!-- Section Heading -->
  <h2 class="text-[22px] leading-snug font-medium text-text-primary mb-6">
    Certifications
  </h2>

  <!-- Editorial Layout Row List -->
  <div class="certifications-list divide-y divide-border/50 border-t border-b border-border/30">
    {certificationsData.map(cert => {
      const isProgress = cert.status === 'in_progress';
      
      return (
        <div class={`py-4 flex flex-col justify-between gap-3 ${isProgress ? 'dev-only curious-only' : 'all-modes'}`}>
          <div class="flex items-start justify-between gap-4">
            <!-- Left Side: Certification Identity -->
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-semibold text-text-primary leading-tight">
                {cert.name}
              </h3>
              <p class="text-xs text-text-secondary mt-1">
                {cert.issuer} &bull; {cert.year}
              </p>
            </div>
            
            <!-- Right Side: Status Badge -->
            <div class="flex items-center justify-end">
              {cert.status === 'completed' ? (
                <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full bg-[var(--badge-completed)] text-[var(--badge-completed-text)] whitespace-nowrap">
                  Completed
                </span>
              ) : (
                <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full bg-[var(--badge-progress)] text-[var(--badge-progress-text)] whitespace-nowrap">
                  In Progress
                </span>
              )}
            </div>
          </div>
          
          <!-- Special Note Handling (e.g. AWS article series note) -->
          {cert.note && (
            <div class="dev-only curious-only mt-0.5">
              <p class="text-xs text-text-secondary italic pl-3 border-l border-accent/40 leading-relaxed">
                {cert.note}
              </p>
            </div>
          )}
        </div>
      );
    })}
  </div>
</section>
