---
import KpiRow from './KpiRow.astro';

interface Bullet {
  text: string;
  audience: string[];
}

interface Kpi {
  value: string;
  label: string;
}

interface Props {
  entry: {
    id: string;
    company: string;
    subtitle?: string;
    title: string;
    dates: string;
    status: string;
    context_tag: string;
    kpis: Kpi[];
    bullets: Bullet[];
    show_recovery_chart?: boolean;
  };
}

const { entry } = Astro.props;
const isTCS = entry.id === 'tcs';
const isIndependentBusiness = entry.context_tag === 'independent_business';

const statusClass = {
  active: 'badge-active',
  ongoing: 'badge-ongoing',
  dim: 'badge-dim',
  done: 'badge-done',
}[entry.status] ?? 'badge-dim';

const statusLabel = {
  active: 'Current',
  ongoing: 'Ongoing',
  dim: 'Concluded',
  done: 'Done',
}[entry.status] ?? entry.status;
---

<div class={`exp-card fade-in ${isIndependentBusiness ? 'dev-only curious-only' : 'all-modes'}`}>
  <!-- Left sidebar: period, badge, context -->
  <div class="exp-sidebar">
    <span class="exp-dates">{entry.dates}</span>
    <span class={`badge ${statusClass}`}>{statusLabel}</span>
    {entry.context_tag && (
      <span class="exp-context dev-only">{entry.context_tag.replace(/_/g, ' ')}</span>
    )}
  </div>

  <!-- Right: content -->
  <div class="exp-content">
    <h3 class="exp-company">{entry.company}</h3>
    {entry.subtitle && <p class="exp-subtitle">{entry.subtitle}</p>}
    <p class="exp-title">{entry.title}</p>

    <ul class="exp-bullets">
      {entry.bullets.map(bullet => (
        <li data-audience={bullet.audience.join(',')}>{bullet.text}</li>
      ))}
    </ul>

    <KpiRow kpis={entry.kpis} />

    <!-- Recovery curve chart — TCS only, recruiter + developer modes -->
    {isTCS && entry.show_recovery_chart && (
      <div class="recovery-chart recruiter-dev">
        <span class="chart-label">Recovery curve — 50% RTO reduction</span>
        <svg width="100%" height="100" viewBox="0 0 400 100" aria-label="Recovery curve showing 50% RTO reduction">
          <line x1="10" y1="20" x2="390" y2="20" stroke="var(--border-strong)" stroke-width="0.75" stroke-dasharray="4 3" />
          <path
            d="M 10 20 L 120 20 L 145 20 L 165 82 L 215 82 L 255 82 L 285 16 L 315 20 L 390 20 L 390 100 L 10 100 Z"
            fill="var(--accent)"
            opacity="0.07"
          />
          <path
            d="M 10 20 L 120 20 L 145 20 L 165 82 L 215 82 L 255 82 L 285 16 L 315 20 L 390 20"
            stroke="var(--accent)"
            stroke-width="1.75"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <text x="20" y="14" font-size="9" font-family="var(--font-mono)" fill="var(--text-disabled)">baseline</text>
          <text x="148" y="98" font-size="9" font-family="var(--font-mono)" fill="var(--text-disabled)">incident</text>
          <text x="288" y="14" font-size="9" font-family="var(--font-mono)" fill="var(--text-disabled)">recovery</text>
        </svg>
      </div>
    )}
  </div>
</div>

<style is:global>
[data-mode="recruiter"] .exp-bullets li[data-audience]:not([data-audience*="recruiter"]):not([data-audience*="management"]) {
  display: none;
}
[data-mode="developer"] .exp-bullets li[data-audience] { display: list-item; }
[data-mode="curious"]   .exp-bullets li[data-audience] { display: list-item; }
</style>

<style>
.exp-card {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: var(--space-8);
  padding: var(--space-8) 0;
  border-bottom: 1px solid var(--border);
  align-items: start;
}
.exp-card:last-child { border-bottom: none; }
@media (max-width: 768px) {
  .exp-card { grid-template-columns: 1fr; gap: var(--space-4); }
}

.exp-sidebar {
  position: sticky;
  top: calc(var(--nav-height) + var(--space-8));
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
@media (max-width: 768px) {
  .exp-sidebar { position: static; flex-direction: row; flex-wrap: wrap; align-items: center; gap: var(--space-3); }
}

.exp-dates {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--text-muted);
  letter-spacing: 0.02em;
}
.exp-context {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text-disabled);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-top: var(--space-1);
}

.exp-content { min-width: 0; }
.exp-company {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 400;
  color: var(--text);
  letter-spacing: -0.01em;
  margin: 0 0 var(--space-1);
  font-optical-sizing: auto;
}
.exp-subtitle {
  font-size: var(--text-xs);
  color: var(--text-muted);
  font-style: italic;
  margin: 0 0 var(--space-3);
}
.exp-title {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--accent-text);
  margin: 0 0 var(--space-5);
  font-family: var(--font-mono);
  letter-spacing: 0.02em;
}
.exp-bullets {
  list-style: disc;
  padding-left: var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  font-size: var(--text-sm);
  color: var(--text-muted);
  line-height: 1.7;
}

.recovery-chart {
  margin-top: var(--space-5);
}
.chart-label {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--text-muted);
  display: block;
  margin-bottom: var(--space-2);
}
</style>
