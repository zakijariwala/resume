---
import resume from '../data/resume.json';
import Terminal from './Terminal.astro';

const { recruiter, developer, curious } = resume.about;
---

<section id="about" class="py-12 border-b border-border transition-all duration-150">
  <!-- Section Heading -->
  <h2 class="text-[22px] leading-snug font-medium text-text-primary mb-6">
    About
  </h2>

  <!-- Editorial Text Container (Strict 640px max-width boundary for optimal readability) -->
  <div class="max-w-[640px] text-base leading-[1.7] text-text-secondary">
    <p class="recruiter-only">
      {recruiter}
    </p>
    
    <p class="dev-only">
      {developer}
    </p>
    
    <p class="curious-only">
      {curious}
    </p>
    
    <!-- Developer Mode Terminal Easter Egg (Only rendered in Developer View) -->
    <Terminal />
  </div>
</section>
