---
interface Bullet {
  text: string;
  audience: string[];
}

interface Props {
  project: {
    id: string;
    name: string;
    tagline: string;
    one_line_summary: string;
    featured_metric: string;
    why_i_built_it: string;
    tech: string[];
    github: string;
    year: string;
    bullets: Bullet[];
  };
}

const { project } = Astro.props;
const visibleTech = project.tech.slice(0, 6);
const isPrivate = !project.github || project.github === 'private';
---

<div class="proj-card card fade-in" id={`project-${project.id}`}>
  <div class="proj-header">
    <div class="proj-meta">
      <span class="project-tagline">{project.tagline}</span>
      <span class="proj-year recruiter-dev">{project.year}</span>
    </div>
    {project.featured_metric && (
      <span class="project-metric">{project.featured_metric}</span>
    )}
  </div>

  <h3 class="proj-name">{project.name}</h3>
  <p class="proj-summary">{project.one_line_summary}</p>

  <div class="stack-chips">
    {visibleTech.map(t => (
      <span class="stack-chip">{t}</span>
    ))}
  </div>

  <ul class="proj-bullets">
    {project.bullets.map(bullet => (
      <li data-audience={bullet.audience.join(',')}>{bullet.text}</li>
    ))}
  </ul>

  {project.why_i_built_it && (
    <div class="callout curious-only">
      <p class="why-text">{project.why_i_built_it}</p>
    </div>
  )}

  {!isPrivate ? (
    <a
      href={project.github}
      target="_blank"
      rel="noopener noreferrer"
      class="proj-github-link dev-only"
      aria-label={`View ${project.name} on GitHub`}
    >
      <i class="ti ti-brand-github"></i>
      <span>View repo</span>
    </a>
  ) : (
    <span class="proj-private dev-only">
      <i class="ti ti-lock"></i>
      <span>Private repo</span>
    </span>
  )}
</div>

<style is:global>
[data-mode="recruiter"] .proj-bullets li[data-audience]:not([data-audience*="recruiter"]):not([data-audience*="management"]) {
  display: none;
}
[data-mode="developer"] .proj-bullets li[data-audience] { display: list-item; }
[data-mode="curious"]   .proj-bullets li[data-audience] { display: list-item; }
</style>

<style>
.proj-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  height: 100%;
}
.proj-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-3);
}
.proj-meta {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  flex-wrap: wrap;
}
.project-tagline {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--text-muted);
  letter-spacing: 0.04em;
}
.proj-year {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--text-disabled);
}
.proj-name {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 400;
  color: var(--text);
  letter-spacing: -0.01em;
  margin: 0;
  line-height: 1.25;
  font-optical-sizing: auto;
}
.proj-summary {
  font-size: var(--text-sm);
  color: var(--text-muted);
  line-height: 1.7;
  margin: 0;
  flex: 1;
}
.proj-bullets {
  list-style: disc;
  padding-left: var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  font-size: var(--text-sm);
  color: var(--text-muted);
  line-height: 1.65;
  margin: 0;
}
.why-text {
  font-size: var(--text-sm);
  color: var(--text-muted);
  line-height: 1.75;
  font-style: italic;
  margin: 0;
}
.proj-github-link,
.proj-private {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--accent-text);
  text-decoration: none;
  margin-top: auto;
  padding-top: var(--space-3);
  border-top: 1px solid var(--border);
  transition: color var(--motion-fast);
}
.proj-github-link:hover { text-decoration: underline; }
.proj-private { color: var(--text-disabled); font-style: italic; }
</style>
