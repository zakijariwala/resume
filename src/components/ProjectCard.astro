---
import resume from '../data/resume.json';

interface Props {
  project: typeof import('../data/resume.json').projects[number];
}

const { project } = Astro.props;

// Restrict to a maximum of 8 tech pills
const visibleTech = project.tech.slice(0, 8);

// Separate first 2 bullets from the remaining ones
const initialBullets = project.bullets.slice(0, 2);
const remainingBullets = project.bullets.slice(2);

// Evaluate repository visibility states
const isPrivate = !project.github || project.github === 'private';
const isFullUrlVisible = project.github && project.github.startsWith('https://github.com/zakijariwala/');
---

<div class="project-card-wrapper border border-border bg-surface p-4 rounded-lg mb-4 transition-colors duration-150" id={`project-${project.id}`}>
  <!-- Top Meta Row -->
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-[17px] font-semibold text-text-primary leading-tight">
      {project.name}
    </h3>
    
    {project.featured_metric && (
      <span class="text-xs font-mono font-semibold text-accent whitespace-nowrap pt-0.5">
        {project.featured_metric}
      </span>
    )}
  </div>

  <!-- One-liner Description -->
  <p class="text-base text-text-primary font-normal mt-2 mb-3 leading-relaxed">
    {project.one_line_summary}
  </p>

  <!-- Technology Stack Pill Row (Never horizontal-scrolls, wraps naturally) -->
  <div class="flex flex-wrap gap-1.5 mb-4" aria-label="Technologies used">
    {visibleTech.map(techName => (
      <span class="tech-pill px-2.5 py-0.5 text-xs font-mono font-medium bg-surface border border-border rounded-pill text-text-primary whitespace-nowrap">
        {techName}
      </span>
    ))}
  </div>

  <!-- Project Bullets -->
  <div class="project-bullets-root">
    <!-- Initial Bullets (Always visible, filtered by CSS data-mode) -->
    <ul class="list-disc pl-4 space-y-2 text-[14.5px] leading-relaxed text-text-secondary">
      {initialBullets.map(bullet => (
        <li data-audience={bullet.audience.join(',')}>
          {bullet.text}
        </li>
      ))}
    </ul>

    <!-- Expandable Bullet Section -->
    {remainingBullets.length > 0 || project.why_i_built_it ? (
      <div 
        id={`drawer-${project.id}`}
        class="project-details-drawer max-h-0 overflow-hidden transition-[max-height] duration-300 ease-out"
      >
        <div class="pt-2 mt-2">
          {remainingBullets.length > 0 && (
            <ul class="list-disc pl-4 space-y-2 text-[14.5px] leading-relaxed text-text-secondary">
              {remainingBullets.map(bullet => (
                <li data-audience={bullet.audience.join(',')}>
                  {bullet.text}
                </li>
              ))}
            </ul>
          )}
          
          {project.why_i_built_it && (
            <p 
              id={`why-${project.id}`}
              class="curious-only details-hidden border-l-2 border-accent pl-3 text-sm text-text-secondary italic mt-3 leading-relaxed"
            >
              {project.why_i_built_it}
            </p>
          )}
        </div>
      </div>
      
      <!-- Show Details Trigger Toggle -->
      <button
        class="proj-toggle-btn mt-3 text-xs font-semibold text-accent cursor-pointer flex items-center gap-1 focus-visible:outline-accent"
        aria-expanded="false"
        aria-controls={`drawer-${project.id}`}
        data-target={`drawer-${project.id}`}
        data-why={`why-${project.id}`}
      >
        <span>+ Show details</span>
      </button>
    ) : null}
  </div>

  <!-- Repository Link Row (Visible in Developer Mode only) -->
  <div class="dev-only border-t border-border mt-4 pt-3 flex items-center text-sm min-w-0">
    {isPrivate ? (
      <div class="flex items-center gap-1.5 text-text-secondary italic">
        <i class="ti ti-lock text-base"></i>
        <span>Private repo</span>
      </div>
    ) : (
      <a
        href={project.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-accent font-medium hover:underline focus-visible:outline-accent min-w-0 w-full"
      >
        <i class="ti ti-brand-github text-base shrink-0"></i>
        <span class="truncate">{isFullUrlVisible ? project.github : 'View Repository'}</span>
      </a>
    )}
  </div>
</div>

<style is:global>
  /* CSS-Driven bullet filters (reusable rules matching ExperienceCard patterns) */
  [data-mode="recruiter"] li[data-audience]:not([data-audience*="recruiter"]):not([data-audience*="management"]) {
    display: none !important;
  }
  [data-mode="developer"] li[data-audience] {
    display: list-item !important;
  }
  [data-mode="curious"] li[data-audience] {
    display: list-item !important;
  }

  /* Combined visibility logic: visible only when mode is curious AND details are expanded */
  .curious-only.details-hidden {
    display: none !important;
  }

  /* Active transition selectors triggering drawer reveals */
  [aria-expanded="true"] + .project-details-drawer {
    max-height: 2000px !important;
  }
</style>

<script>
  function registerProjectHandlers() {
    const toggleButtons = document.querySelectorAll('.proj-toggle-btn');
    
    toggleButtons.forEach(btn => {
      if (btn.getAttribute('data-listener-active') === 'true') return;
      
      const targetId = btn.getAttribute('data-target');
      const whyId = btn.getAttribute('data-why');
      const drawer = targetId ? document.getElementById(targetId) : null;
      const whyParagraph = whyId ? document.getElementById(whyId) : null;
      
      if (!drawer) return;
      
      btn.addEventListener('click', () => {
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';
        const nextState = !isExpanded;
        
        btn.setAttribute('aria-expanded', nextState ? 'true' : 'false');
        btn.querySelector('span')!.textContent = nextState ? '− Hide details' : '+ Show details';
        
        // Control details-hidden class to satisfy mode AND expansion conditions on why_i_built_it
        if (whyParagraph) {
          if (nextState) {
            whyParagraph.classList.remove('details-hidden');
          } else {
            whyParagraph.classList.add('details-hidden');
          }
        }
      });
      
      btn.setAttribute('data-listener-active', 'true');
    });
  }

  document.addEventListener('DOMContentLoaded', registerProjectHandlers);
  document.addEventListener('astro:page-load', registerProjectHandlers);
</script>
