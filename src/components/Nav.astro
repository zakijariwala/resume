---
import meta from '../data/meta.json';

const { name } = meta;
---

<!-- Desktop top nav -->
<header
  class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 transition-colors duration-150"
  style="height: var(--nav-height); background: var(--nav-bg); border-bottom: 1px solid var(--border); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
>
  <!-- Logo / name -->
  <a
    href="#hero"
    class="hidden lg:block font-body text-sm font-semibold truncate max-w-[200px] transition-colors duration-150"
    style="color: var(--text);"
    aria-label="Back to top"
  >
    {name}
  </a>

  <!-- Desktop nav links -->
  <nav class="hidden lg:flex items-center gap-5" aria-label="Main navigation">
    <a href="#about" class="desktop-nav-link nav-link">About</a>
    <a href="#experience" class="desktop-nav-link nav-link">Experience</a>
    <a href="#projects" class="desktop-nav-link nav-link">Projects</a>
    <a href="#skills" class="desktop-nav-link nav-link">Skills</a>
    <a href="#certifications" class="desktop-nav-link nav-link">Certs</a>
    <a href="#contact" class="desktop-nav-link nav-link">Contact</a>
  </nav>

  <!-- Right controls: mode switcher + theme toggle -->
  <div class="flex items-center gap-3">
    <!-- Mode switcher with label + coachmark -->
    <div class="mode-switch-wrapper">
      <span class="mode-switch-label">Viewing as</span>
      <div
        class="audience-switch flex p-0.5 rounded-full"
        style="background: var(--bg); border: 1px solid var(--border);"
        role="radiogroup"
        aria-label="Select audience perspective"
      >
        <button class="audience-btn" data-mode-btn="recruiter" role="radio" aria-checked="false">Recruiter</button>
        <button class="audience-btn" data-mode-btn="developer" role="radio" aria-checked="false">Developer</button>
        <button class="audience-btn" data-mode-btn="curious" role="radio" aria-checked="false">Curious</button>
      </div>
      <div id="mode-coachmark" class="mode-coachmark" aria-hidden="true">
        <span>This site has 3 perspectives — try switching</span>
        <button class="coachmark-close" id="coachmark-close" aria-label="Dismiss hint">×</button>
      </div>
    </div>

    <!-- Theme toggle -->
    <button
      class="theme-toggle-btn w-8 h-8 rounded-full flex items-center justify-center transition-colors duration-150"
      style="border: 1px solid var(--border); background: var(--surface);"
      aria-label="Toggle light/dark theme"
    >
      <i class="ti ti-moon text-base" id="theme-icon" style="color: var(--text);"></i>
    </button>
  </div>
</header>

<!-- Mobile bottom nav -->
<nav
  class="fixed bottom-0 left-0 right-0 z-50 flex items-center justify-around lg:hidden"
  style="height: var(--nav-height); background: var(--nav-bg); border-top: 1px solid var(--border); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
  aria-label="Mobile navigation"
>
  <a href="#about" class="mobile-nav-link mob-link"><i class="ti ti-user text-lg"></i><span>About</span></a>
  <a href="#experience" class="mobile-nav-link mob-link"><i class="ti ti-briefcase text-lg"></i><span>Work</span></a>
  <a href="#projects" class="mobile-nav-link mob-link"><i class="ti ti-code text-lg"></i><span>Projects</span></a>
  <a href="#skills" class="mobile-nav-link mob-link"><i class="ti ti-cpu text-lg"></i><span>Skills</span></a>
  <a href="#contact" class="mobile-nav-link mob-link"><i class="ti ti-mail text-lg"></i><span>Contact</span></a>
</nav>

<style>
.nav-link {
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  color: var(--text-muted);
  text-decoration: none;
  transition: color var(--motion-fast);
}
.nav-link:hover,
.nav-link.active { color: var(--accent); }

.audience-btn {
  padding: 2px 12px;
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  border-radius: 9999px;
  min-height: 26px;
  border: none;
  background: transparent;
  cursor: pointer;
  transition: color var(--motion-fast), background var(--motion-fast);
}
.audience-btn:hover { color: var(--text); }
.audience-btn.active,
[data-mode="recruiter"] [data-mode-btn="recruiter"],
[data-mode="developer"] [data-mode-btn="developer"],
[data-mode="curious"]   [data-mode-btn="curious"] {
  background: var(--accent);
  color: #fff;
}

.mob-link {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 4px 0;
  font-family: var(--font-body);
  font-size: 10px;
  font-weight: 600;
  color: var(--text-muted);
  text-decoration: none;
  gap: 2px;
  transition: color var(--motion-fast);
}
.mob-link:hover,
.mob-link.active { color: var(--accent); }

.mode-switch-wrapper {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  position: relative;
}
.mode-switch-label {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text-disabled);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  white-space: nowrap;
}
.mode-coachmark {
  position: absolute;
  top: calc(100% + 10px);
  right: 0;
  background: var(--surface-raised);
  border: 1px solid var(--border-strong);
  border-radius: var(--radius-sm);
  padding: var(--space-2) var(--space-4);
  font-family: var(--font-body);
  font-size: var(--text-xs);
  color: var(--text-muted);
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: var(--space-3);
  z-index: 100;
  animation: coachmark-in 0.25s ease both;
  animation-delay: 1.2s;
  opacity: 0;
}
.mode-coachmark::before {
  content: '';
  position: absolute;
  top: -5px;
  right: 28px;
  width: 8px;
  height: 8px;
  background: var(--surface-raised);
  border-left: 1px solid var(--border-strong);
  border-top: 1px solid var(--border-strong);
  transform: rotate(45deg);
}
.mode-coachmark.hidden { display: none; }
@keyframes coachmark-in {
  from { opacity: 0; transform: translateY(-4px); }
  to   { opacity: 1; transform: translateY(0); }
}
.coachmark-close {
  background: none;
  border: none;
  color: var(--text-disabled);
  cursor: pointer;
  font-size: 16px;
  line-height: 1;
  padding: 0 0 0 var(--space-1);
  transition: color var(--motion-fast);
}
.coachmark-close:hover { color: var(--text); }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const modeButtons = document.querySelectorAll<HTMLButtonElement>('[data-mode-btn]');
  const toast = document.getElementById('mode-toast');
  let toastTimer: ReturnType<typeof setTimeout> | undefined;

  // Coachmark — show once on first visit, dismiss on mode switch or close
  const coachmark = document.getElementById('mode-coachmark');
  const coachmarkClose = document.getElementById('coachmark-close');

  function dismissCoachmark() {
    if (coachmark) {
      coachmark.classList.add('hidden');
      localStorage.setItem('portfolio_coachmark_seen', '1');
    }
  }

  if (coachmark) {
    if (localStorage.getItem('portfolio_coachmark_seen')) {
      coachmark.classList.add('hidden');
    }
    if (coachmarkClose) {
      coachmarkClose.addEventListener('click', dismissCoachmark);
    }
  }

  function setMode(mode: string) {
    document.documentElement.setAttribute('data-mode', mode);
    document.body.setAttribute('data-mode', mode);
    localStorage.setItem('portfolio_mode', mode);
    window.history.replaceState(null, '', '?mode=' + mode);
    dismissCoachmark();

    modeButtons.forEach(btn => {
      const active = btn.dataset.modeBtn === mode;
      btn.classList.toggle('active', active);
      btn.setAttribute('aria-checked', active ? 'true' : 'false');
    });

    if (toast) {
      clearTimeout(toastTimer);
      const labels: Record<string, string> = {
        recruiter: 'Recruiter view',
        developer: 'Developer view',
        curious: 'Curious view',
      };
      toast.textContent = labels[mode] ?? '';
      toast.classList.remove('opacity-0');
      toast.classList.add('opacity-100');
      toastTimer = setTimeout(() => {
        toast.classList.remove('opacity-100');
        toast.classList.add('opacity-0');
      }, 1400);
    }

    window.dispatchEvent(new CustomEvent('portfolio-mode-change', { detail: { mode } }));
  }

  modeButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const mode = btn.dataset.modeBtn;
      if (mode) setMode(mode);
    });
  });

  const initialMode = document.documentElement.getAttribute('data-mode') || 'recruiter';
  setMode(initialMode);

  // Theme toggle
  const themeBtn = document.querySelector<HTMLButtonElement>('.theme-toggle-btn');
  const themeIcon = document.getElementById('theme-icon');

  function syncThemeIcon(theme: string) {
    if (themeIcon) {
      themeIcon.className = theme === 'dark'
        ? 'ti ti-sun text-base'
        : 'ti ti-moon text-base';
    }
  }

  function toggleTheme() {
    const current = document.documentElement.getAttribute('data-theme') || 'light';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    document.body.setAttribute('data-theme', next);
    localStorage.setItem('portfolio_theme', next);
    syncThemeIcon(next);
  }

  if (themeBtn) themeBtn.addEventListener('click', toggleTheme);
  syncThemeIcon(document.documentElement.getAttribute('data-theme') || 'light');

  // Active nav link tracker
  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const desktopLinks = document.querySelectorAll<HTMLAnchorElement>('.desktop-nav-link');
  const mobileLinks = document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link');

  const navObserver = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const id = entry.target.getAttribute('id');
      [...desktopLinks, ...mobileLinks].forEach(link => {
        const matches = link.getAttribute('href') === `#${id}`;
        link.classList.toggle('active', matches);
      });
    });
  }, { threshold: 0.4 });

  sections.forEach(s => navObserver.observe(s));
});
</script>
