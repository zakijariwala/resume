---
import resume from '../data/resume.json';

const { name } = resume.meta;
---

<!-- Sticky Top Bar (Contains branding and navigation on Desktop, mode controls on Mobile) -->
<div class="fixed top-0 left-0 right-0 h-[52px] bg-surface border-b border-border z-50 flex items-center justify-between px-4 transition-colors duration-150">
  <!-- Left Side: Branding / Name (Desktop Only) -->
  <div class="hidden lg:block text-sm font-semibold text-text-primary truncate max-w-[220px]">
    {name}
  </div>

  <!-- Center: Main Navigation List (Desktop Only) -->
  <div class="hidden lg:flex items-center gap-6">
    <a href="#about" class="desktop-nav-link text-sm font-medium text-text-secondary hover:text-accent transition-colors">About</a>
    <a href="#experience" class="desktop-nav-link text-sm font-medium text-text-secondary hover:text-accent transition-colors">Experience</a>
    <a href="#projects" class="desktop-nav-link text-sm font-medium text-text-secondary hover:text-accent transition-colors">Projects</a>
    <a href="#skills" class="desktop-nav-link text-sm font-medium text-text-secondary hover:text-accent transition-colors">Skills</a>
    <a href="#certifications" class="desktop-nav-link text-sm font-medium text-text-secondary hover:text-accent transition-colors">Certifications</a>
    <a href="#contact" class="desktop-nav-link text-sm font-medium text-text-secondary hover:text-accent transition-colors">Contact</a>
  </div>

  <!-- Right Side: Controls (Mode Switcher & Theme Toggle - Responsive Layout) -->
  <div class="flex items-center justify-between w-full lg:w-auto lg:gap-3">
    <!-- Mode Selection Pill Control -->
    <div class="audience-switch flex bg-background border border-border p-0.5 rounded-pill relative" role="radiogroup" aria-label="Audience perspective selector">
      <button class="audience-btn px-4 py-0.5 text-xs font-semibold text-text-secondary rounded-pill min-h-[28px] transition-colors focus-visible:outline-accent" data-mode-btn="recruiter" role="radio" aria-checked="false">Recruiter</button>
      <button class="audience-btn px-4 py-0.5 text-xs font-semibold text-text-secondary rounded-pill min-h-[28px] transition-colors focus-visible:outline-accent" data-mode-btn="developer" role="radio" aria-checked="false">Developer</button>
      <button class="audience-btn px-4 py-0.5 text-xs font-semibold text-text-secondary rounded-pill min-h-[28px] transition-colors focus-visible:outline-accent" data-mode-btn="curious" role="radio" aria-checked="false">Curious</button>
    </div>

    <!-- Theme Toggle Control -->
    <button class="theme-toggle-btn w-8 h-8 rounded-full border border-border flex items-center justify-center bg-surface hover:bg-background transition-colors focus-visible:outline-accent" aria-label="Toggle visual theme">
      <i class="ti ti-moon text-lg text-text-primary" id="theme-toggle-icon"></i>
    </button>
  </div>
</div>

<!-- Mobile Bottom Sticky Navigation (Hidden on Desktop) -->
<nav class="fixed bottom-0 left-0 right-0 h-[52px] bg-surface border-t border-border z-50 flex items-center justify-around lg:hidden transition-colors duration-150" aria-label="Mobile Bottom Navigation">
  <a href="#about" class="mobile-nav-link flex flex-col items-center justify-center text-text-secondary hover:text-accent transition-colors flex-1 py-1 focus-visible:outline-accent">
    <i class="ti ti-user text-lg"></i>
    <span class="text-[10px] font-semibold mt-0.5">About</span>
  </a>
  <a href="#experience" class="mobile-nav-link flex flex-col items-center justify-center text-text-secondary hover:text-accent transition-colors flex-1 py-1 focus-visible:outline-accent">
    <i class="ti ti-briefcase text-lg"></i>
    <span class="text-[10px] font-semibold mt-0.5">Experience</span>
  </a>
  <a href="#projects" class="mobile-nav-link flex flex-col items-center justify-center text-text-secondary hover:text-accent transition-colors flex-1 py-1 focus-visible:outline-accent">
    <i class="ti ti-code text-lg"></i>
    <span class="text-[10px] font-semibold mt-0.5">Projects</span>
  </a>
  <a href="#skills" class="mobile-nav-link flex flex-col items-center justify-center text-text-secondary hover:text-accent transition-colors flex-1 py-1 focus-visible:outline-accent">
    <i class="ti ti-cpu text-lg"></i>
    <span class="text-[10px] font-semibold mt-0.5">Skills</span>
  </a>
  <a href="#certifications" class="mobile-nav-link flex flex-col items-center justify-center text-text-secondary hover:text-accent transition-colors flex-1 py-1 focus-visible:outline-accent">
    <i class="ti ti-certificate text-lg"></i>
    <span class="text-[10px] font-semibold mt-0.5">Certs</span>
  </a>
  <a href="#contact" class="mobile-nav-link flex flex-col items-center justify-center text-text-secondary hover:text-accent transition-colors flex-1 py-1 focus-visible:outline-accent">
    <i class="ti ti-mail text-lg"></i>
    <span class="text-[10px] font-semibold mt-0.5">Contact</span>
  </a>
</nav>

<style>
  /* Robust Pure-CSS Perspective Activators (Resilient if JS is delayed) */
  [data-mode="recruiter"] [data-mode-btn="recruiter"],
  [data-mode="developer"] [data-mode-btn="developer"],
  [data-mode="curious"] [data-mode-btn="curious"],
  [data-mode-btn].active {
    background-color: var(--accent) !important;
    color: #FFFFFF !important;
  }
</style>

<script>
  // Block execution until DOM binds completely
  document.addEventListener('DOMContentLoaded', () => {
    const modeButtons = document.querySelectorAll('[data-mode-btn]');
    const modeToast = document.getElementById('mode-toast');
    let toastTimeout: number | undefined;
    
    // --- Mode Synchronization Core ---
    function setMode(mode: string) {
      document.documentElement.setAttribute('data-mode', mode);
      document.body.setAttribute('data-mode', mode);
      document.body.dataset.mode = mode;
      
      localStorage.setItem('portfolio_mode', mode);
      
      // Sync URL parameter silently
      window.history.replaceState(null, '', '?mode=' + mode);
      
      // Update active control states
      modeButtons.forEach(btn => {
        const button = btn as HTMLElement;
        const isActive = button.dataset.modeBtn === mode;
        button.classList.toggle('active', isActive);
        button.setAttribute('aria-checked', isActive ? 'true' : 'false');
      });

      // Mode-Change Visual Toast Notification
      if (modeToast) {
        if (toastTimeout) {
          clearTimeout(toastTimeout);
        }

        const toastMessages: Record<string, string> = {
          recruiter: "Showing recruiter view",
          developer: "Showing developer view",
          curious: "Showing curious view"
        };

        modeToast.textContent = toastMessages[mode] || "";
        modeToast.classList.remove('opacity-0', 'pointer-events-none');
        modeToast.classList.add('opacity-100');

        toastTimeout = window.setTimeout(() => {
          modeToast.classList.remove('opacity-100');
          modeToast.classList.add('opacity-0', 'pointer-events-none');
        }, 1200);
      }
      
      // Propagate event for potential sub-module canvas updates
      window.dispatchEvent(new CustomEvent('portfolio-mode-change', { detail: { mode } }));
    }

    modeButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const button = btn as HTMLElement;
        const targetMode = button.dataset.modeBtn;
        if (targetMode) {
          setMode(targetMode);
        }
      });
    });

    // Initialize Mode UI active states
    const activeMode = document.documentElement.getAttribute('data-mode') || 'recruiter';
    setMode(activeMode);

    // --- Theme Synchronization Core ---
    const themeButton = document.querySelector('.theme-toggle-btn');
    const themeIcon = document.getElementById('theme-toggle-icon');

    function updateThemeUI(theme: string) {
      if (themeIcon) {
        themeIcon.className = theme === 'dark' ? 'ti ti-sun text-lg text-text-primary' : 'ti ti-moon text-lg text-text-primary';
      }
    }

    function toggleTheme() {
      const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
      const targetTheme = currentTheme === 'dark' ? 'light' : 'dark';
      
      document.documentElement.setAttribute('data-theme', targetTheme);
      document.body.setAttribute('data-theme', targetTheme);
      localStorage.setItem('portfolio_theme', targetTheme);
      
      updateThemeUI(targetTheme);
    }

    if (themeButton) {
      themeButton.addEventListener('click', toggleTheme);
    }

    // Initialize Theme UI Icons
    const activeTheme = document.documentElement.getAttribute('data-theme') || 'light';
    updateThemeUI(activeTheme);

    // --- Navigation Viewport Active Highlight Tracker ---
    const sections = document.querySelectorAll('section[id]');
    const mobileLinks = document.querySelectorAll('.mobile-nav-link');
    const desktopLinks = document.querySelectorAll('.desktop-nav-link');

    const observerOptions = {
      root: null,
      threshold: 0.5 // Active style triggers when section occupies >50% of viewport
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          
          // Sync Mobile Bottom Nav Anchors
          mobileLinks.forEach(link => {
            const href = link.getAttribute('href');
            if (href === `#${id}`) {
              link.classList.add('text-accent');
              link.classList.remove('text-text-secondary');
            } else {
              link.classList.remove('text-accent');
              link.classList.add('text-text-secondary');
            }
          });

          // Sync Desktop Horizontal Nav Anchors
          desktopLinks.forEach(link => {
            const href = link.getAttribute('href');
            if (href === `#${id}`) {
              link.classList.add('text-accent');
              link.classList.remove('text-text-secondary');
            } else {
              link.classList.remove('text-accent');
              link.classList.add('text-text-secondary');
            }
          });
        }
      });
    }, observerOptions);

    sections.forEach(section => observer.observe(section));
  });
</script>
