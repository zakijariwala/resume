---
import resume from '../data/resume.json';

// Build-time evaluation of data structures to prevent client-side parsing costs
const projectsList = resume.projects.map(p => `${p.id}: ${p.one_line_summary}`);

const aiProjects = resume.projects
  .filter(p => 
    p.name.toUpperCase().includes('AI') || 
    p.one_line_summary.toUpperCase().includes('AI') || 
    p.tech.some(t => ['AI', 'CLAUDE', 'GEMINI'].some(term => t.toUpperCase().includes(term)))
  )
  .map(p => `${p.id}: ${p.one_line_summary}`);

const confidentSkills = resume.skills
  .flatMap(c => c.items)
  .filter(s => s.proficiency === 'confident')
  .map(s => s.name)
  .join(', ');

const contactInfo = `Email: ${resume.meta.email}\nLinkedIn: ${resume.meta.linkedin}`;
---

<div class="dev-only mt-8" aria-label="Developer Interactive Terminal Easter Egg">
  <!-- Interactive Terminal Label -->
  <span class="text-xs font-mono text-text-secondary block mb-2 select-none">
    // interactive terminal
  </span>

  <!-- Terminal Panel Container -->
  <div class="terminal-container w-full max-w-[640px] h-[280px] bg-[#0D1117] rounded-md border border-[#30363D] flex flex-col font-mono text-[13px] text-[#C9D1D9] overflow-hidden select-text">
    <!-- macOS style decorative header bar -->
    <div class="flex items-center justify-between px-3 py-1.5 bg-[#161B22] border-b border-[#30363D] select-none shrink-0">
      <div class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
        <span class="w-3 h-3 rounded-full bg-[#FEBC2E]"></span>
        <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
      </div>
      <span class="text-xs text-[#8B949E] font-sans">zaki@portfolio: ~</span>
      <div class="w-12"></div>
    </div>

    <!-- Scrollable terminal console body -->
    <div class="flex-1 p-3 overflow-y-auto flex flex-col gap-2 cursor-text" id="terminal-body">
      <div class="terminal-history flex flex-col gap-2" id="terminal-history">
        <div class="text-[#8B949E] mb-1 select-none">Mohammad Zaki Jariwala Portfolio Terminal. Type 'help' for options.</div>
      </div>
      
      <!-- Input line row -->
      <div class="flex items-center gap-1.5 shrink-0">
        <span class="text-[#58A6FF] font-semibold shrink-0 select-none">[zaki@portfolio ~]$</span>
        <div class="flex-1 flex items-center relative min-w-0">
          <input 
            type="text" 
            id="terminal-input"
            class="w-full bg-transparent border-none outline-none text-[#C9D1D9] font-mono text-[13px] p-0 m-0 caret-[#58A6FF] focus:ring-0 focus:border-none focus:outline-none"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            aria-label="Terminal command input"
          />
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ projectsList, aiProjects, confidentSkills, contactInfo }}>
  document.addEventListener('DOMContentLoaded', () => {
    const termInput = document.getElementById('terminal-input');
    const termHistory = document.getElementById('terminal-history');
    const termBody = document.getElementById('terminal-body');
    
    if (!termInput || !termHistory || !termBody) return;
    
    let lastCommand = '';

    // Auto-focus input when clicking inside the terminal bounds
    termBody.addEventListener('click', () => {
      termInput.focus();
    });

    function printLine(text, type = 'output') {
      const line = document.createElement('div');
      
      if (type === 'prompt') {
        line.innerHTML = `<span class="text-[#58A6FF] font-semibold select-none">[zaki@portfolio ~]$</span> <span class="select-text">${text}</span>`;
      } else {
        // Render simple newline-separated texts cleanly
        line.innerHTML = text.replace(/\n/g, '<br>');
        if (type === 'error') {
          line.classList.add('text-[#FF7B72]');
        }
      }
      
      termHistory.appendChild(line);
      termBody.scrollTop = termBody.scrollHeight;
    }

    termInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const rawCmd = termInput.value.trim();
        const cmdClean = rawCmd.toLowerCase().replace(/\s+/g, ' ');
        termInput.value = '';

        if (!rawCmd) return;

        lastCommand = rawCmd;
        printLine(rawCmd, 'prompt');

        if (cmdClean === 'clear') {
          termHistory.innerHTML = '';
        } else if (cmdClean === 'help') {
          printLine('Available commands:\n  help                  - list available options\n  whoami                - bio summary\n  projects              - view project metrics\n  projects --filter=ai  - filter to AI pipelines\n  skills                - confident engineering skills\n  contact               - mail/linkedin links\n  clear                 - clear console history');
        } else if (cmdClean === 'whoami') {
          printLine('Mohammad Zaki Jariwala — Systems Engineer, Mumbai');
        } else if (cmdClean === 'projects') {
          projectsList.forEach(p => printLine(p));
        } else if (cmdClean === 'projects --filter=ai') {
          aiProjects.forEach(p => printLine(p));
        } else if (cmdClean === 'skills') {
          printLine(confidentSkills);
        } else if (cmdClean === 'contact') {
          printLine(contactInfo);
        } else {
          printLine(`command not found: ${rawCmd}. Type 'help' for options.`, 'error');
        }
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (lastCommand) {
          termInput.value = lastCommand;
        }
      }
    });
  });
</script>
