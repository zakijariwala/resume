---
import skills from '../data/skills.json';
import SectionHeader from './SectionHeader.astro';
---

<section id="skills" class="section-spacing" style="border-bottom: 1px solid var(--border);">
  <SectionHeader
    label="SKILLS"
    labelDev="skills"
    labelCurious="Skills"
    title="Skills"
  />

  <!-- Proficiency legend -->
  <div class="skill-legend fade-in" aria-hidden="true">
    <div class="legend-item">
      <span class="legend-dot confident"></span>
      <span>Confident</span>
    </div>
    <div class="legend-item">
      <span class="legend-dot familiar"></span>
      <span>Familiar</span>
    </div>
    <div class="legend-item dev-only">
      <span class="legend-dot learning"></span>
      <span>Learning</span>
    </div>
  </div>

  <!-- Tab nav -->
  <div class="skill-tabs fade-in" role="tablist" aria-label="Skill categories">
    {skills.map((cat, i) => (
      <button
        class={`skill-tab-btn${i === 0 ? ' active' : ''}`}
        role="tab"
        data-skill-tab={cat.tab_label}
        aria-selected={i === 0 ? 'true' : 'false'}
        aria-controls={`skill-panel-${cat.tab_label}`}
        id={`skill-tab-${cat.tab_label}`}
      >
        {cat.tab_label}
      </button>
    ))}
  </div>

  <!-- Tab panels -->
  {skills.map((cat, i) => (
    <div
      class={`skill-panel${i === 0 ? ' active' : ''}`}
      role="tabpanel"
      id={`skill-panel-${cat.tab_label}`}
      aria-labelledby={`skill-tab-${cat.tab_label}`}
      data-skill-panel={cat.tab_label}
    >
      <div class="skill-pills">
        {cat.items.map(skill => {
          if (skill.proficiency === 'confident') {
            return (
              <span class="skill-pill confident">{skill.name}</span>
            );
          } else if (skill.proficiency === 'familiar') {
            return (
              <span class="skill-pill familiar">{skill.name}</span>
            );
          } else {
            return (
              <span class="skill-pill learning dev-only">{skill.name}</span>
            );
          }
        })}
      </div>
    </div>
  ))}
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const tabs = document.querySelectorAll<HTMLButtonElement>('.skill-tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.skill-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.skillTab;

      tabs.forEach(t => {
        t.classList.toggle('active', t === tab);
        t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
      });
      panels.forEach(p => {
        p.classList.toggle('active', p.dataset.skillPanel === target);
      });
    });
  });
});
</script>

<style>
.section-spacing {
  padding: var(--section-padding) 0;
}
.skill-legend {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-5);
  margin-bottom: var(--space-6);
}
.legend-item {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--text-muted);
}
.legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 9999px;
  flex-shrink: 0;
}
.legend-dot.confident { background: var(--accent); }
.legend-dot.familiar  { background: var(--accent-subtle); border: 1px solid var(--accent-border); }
.legend-dot.learning  { border: 1px solid var(--accent); background: transparent; }

.skill-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-bottom: var(--space-6);
  border-bottom: 1px solid var(--border);
  padding-bottom: var(--space-3);
}
.skill-tab-btn {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.06em;
  color: var(--text-muted);
  background: transparent;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: var(--space-2) var(--space-4);
  cursor: pointer;
  transition: color var(--motion-fast), background var(--motion-fast), border-color var(--motion-fast);
}
.skill-tab-btn:hover {
  color: var(--text);
  border-color: var(--border-strong);
}
.skill-tab-btn.active {
  background: var(--accent-subtle);
  color: var(--accent-text);
  border-color: var(--accent-border);
}

.skill-panel { display: none; }
.skill-panel.active { display: block; }

.skill-pills {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  padding: var(--space-4) 0;
}
.skill-pill {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-pill);
  white-space: nowrap;
}
.skill-pill.confident {
  background: var(--accent);
  color: #fff;
}
.skill-pill.familiar {
  background: var(--accent-subtle);
  color: var(--accent-text);
  border: 1px solid var(--accent-border);
}
.skill-pill.learning {
  background: transparent;
  color: var(--accent-text);
  border: 1px solid var(--accent-border);
}
</style>
