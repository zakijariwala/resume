---
import meta from '../data/meta.json';
import SectionHeader from './SectionHeader.astro';

const { email, whatsapp, phone, linkedin, github, contact_taglines, contact_headline } = meta;

const linkedinDisplay = linkedin.replace('https://', '');
const githubDisplay = github.replace('https://', '');
---

<section id="contact" class="section-spacing contact-bottom">
  <SectionHeader
    label="GET IN TOUCH"
    labelDev="contact"
    labelCurious="Say hello"
    title="Contact"
  />

  <div class="contact-grid">
    <!-- Left: links + tagline -->
    <div class="contact-left fade-in">
      <h3 class="contact-headline">
        <span class="recruiter-only">{contact_headline.recruiter}</span>
        <span class="dev-only">{contact_headline.developer}</span>
        <span class="curious-only">{contact_headline.curious}</span>
      </h3>

      <p class="contact-tagline">
        <span class="recruiter-only">{contact_taglines.recruiter}</span>
        <span class="dev-only">{contact_taglines.developer}</span>
        <span class="curious-only">{contact_taglines.curious}</span>
      </p>

      <a href={`mailto:${email}`} class="contact-email" aria-label={`Email ${email}`}>
        {email}
      </a>

      <div class="contact-links">
        <a href={linkedin} target="_blank" rel="noopener noreferrer" class="contact-link">
          <i class="ti ti-brand-linkedin"></i>
          <span>{linkedinDisplay}</span>
        </a>
        <a href={github} target="_blank" rel="noopener noreferrer" class="contact-link">
          <i class="ti ti-brand-github"></i>
          <span>{githubDisplay}</span>
        </a>
        {whatsapp && (
          <a href={whatsapp} target="_blank" rel="noopener noreferrer" class="contact-link">
            <i class="ti ti-brand-whatsapp"></i>
            <span>WhatsApp · {phone}</span>
          </a>
        )}
      </div>
    </div>

    <!-- Right: contact form -->
    <div class="contact-right fade-in" style="transition-delay: 0.1s;">
      <form
        action="https://formspree.io/f/YOUR_FORM_ID"
        method="POST"
        class="contact-form"
        novalidate
      >
        <div class="form-field">
          <label for="contact-name" class="form-label">Name</label>
          <input
            type="text"
            id="contact-name"
            name="name"
            class="form-input"
            placeholder="Your name"
            required
            autocomplete="name"
          />
        </div>

        <div class="form-field">
          <label for="contact-email" class="form-label">Email</label>
          <input
            type="email"
            id="contact-email"
            name="email"
            class="form-input"
            placeholder="your@email.com"
            required
            autocomplete="email"
          />
        </div>

        <div class="form-field">
          <label for="contact-message" class="form-label">Message</label>
          <textarea
            id="contact-message"
            name="message"
            class="form-textarea"
            placeholder="What's on your mind?"
            rows="5"
            required
          ></textarea>
        </div>

        <button type="submit" class="btn-primary form-submit">
          <i class="ti ti-send" aria-hidden="true"></i>
          <span>Send message</span>
        </button>
      </form>
    </div>
  </div>
</section>

<style>
.section-spacing {
  padding: var(--section-padding) 0;
}
.contact-bottom {
  padding-bottom: calc(var(--nav-height) + var(--space-12));
}
@media (min-width: 769px) {
  .contact-bottom { padding-bottom: var(--section-padding); }
}
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-12);
  align-items: start;
}
@media (max-width: 768px) {
  .contact-grid { grid-template-columns: 1fr; gap: var(--space-8); }
}

.contact-headline {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 400;
  color: var(--text);
  letter-spacing: -0.02em;
  margin: 0 0 var(--space-4);
  font-optical-sizing: auto;
}
[data-mode="curious"] .contact-headline { font-style: italic; }

.contact-tagline {
  font-size: var(--text-sm);
  color: var(--text-muted);
  line-height: 1.7;
  margin: 0 0 var(--space-6);
}

.contact-email {
  display: inline-flex;
  align-items: center;
  font-size: var(--text-lg);
  font-weight: 500;
  color: var(--accent-text);
  text-decoration: none;
  margin-bottom: var(--space-6);
  transition: color var(--motion-fast);
  word-break: break-all;
}
.contact-email:hover {
  text-decoration: underline;
  text-underline-offset: 3px;
}

.contact-links {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
.contact-link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--text-muted);
  text-decoration: none;
  transition: color var(--motion-fast);
  padding: 2px 0;
}
.contact-link:hover { color: var(--accent-text); }
.contact-link i { font-size: 16px; flex-shrink: 0; }

/* Form */
.contact-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}
.form-field {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}
.form-label {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-muted);
}
.form-input,
.form-textarea {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: var(--space-3) var(--space-4);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--text);
  outline: none;
  transition: border-color var(--motion-fast);
  resize: none;
  width: 100%;
  box-sizing: border-box;
}
.form-input:focus,
.form-textarea:focus {
  border-color: var(--accent-border);
}
.form-input::placeholder,
.form-textarea::placeholder {
  color: var(--text-disabled);
}
.form-submit {
  align-self: flex-start;
}
</style>
