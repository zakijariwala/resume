---
import resume from '../data/resume.json';
import ExperienceCard from './ExperienceCard.astro';
---

<section id="experience" class="py-12 border-b border-border transition-all duration-150">
  <!-- Section Heading -->
  <h2 class="text-[22px] leading-snug font-medium text-text-primary mb-6">
    Experience
  </h2>

  <!-- List container for Experience Cards -->
  <div class="experience-cards-container">
    {resume.experience.map(entry => (
      <ExperienceCard entry={entry} />
    ))}
  </div>
</section>
