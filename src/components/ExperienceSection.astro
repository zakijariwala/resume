---
import experience from '../data/experience.json';
import ExperienceCard from './ExperienceCard.astro';
import SectionHeader from './SectionHeader.astro';
---

<section id="experience" class="section-spacing" style="border-bottom: 1px solid var(--border);">
  <SectionHeader
    label="WORK HISTORY"
    labelDev="work_history"
    labelCurious="Where I've worked"
    title="Experience"
  />

  <div class="exp-list">
    {experience.map(entry => (
      <ExperienceCard entry={entry} />
    ))}
  </div>
</section>

<style>
.section-spacing {
  padding: var(--section-padding) 0;
}
.exp-list {
  display: flex;
  flex-direction: column;
}
</style>
